<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Meridian Estate — Prestiżowa Agencja Nieruchomości</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --gold: #B89C6E;
    --gold-light: #D4B88A;
    --gold-dark: #8A7250;
    --cream: #F7F3EC;
    --dark: #0F0E0C;
    --dark-mid: #1A1916;
    --dark-soft: #2A2824;
    --muted: #6B6860;
    --border: rgba(184,156,110,0.2);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--dark);
    color: var(--cream);
    overflow-x: hidden;
  }

  /* ─── NAV ─── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.5rem 4rem;
    background: rgba(15,14,12,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem; font-weight: 300; letter-spacing: 0.2em;
    color: var(--gold); text-transform: uppercase;
  }
  .logo span { font-style: italic; color: var(--cream); }
  nav ul { display: flex; gap: 2.5rem; list-style: none; }
  nav a {
    font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--muted); text-decoration: none; transition: color 0.3s;
  }
  nav a:hover { color: var(--gold); }
  .nav-cta {
    font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--dark); background: var(--gold);
    padding: 0.6rem 1.5rem; border: none; cursor: pointer;
    font-family: 'DM Sans', sans-serif; transition: background 0.3s;
  }
  .nav-cta:hover { background: var(--gold-light); }

  /* ─── HERO ─── */
  .hero {
    min-height: 100vh;
    display: grid; grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 8rem 4rem 4rem;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 60% 80% at 70% 50%, rgba(184,156,110,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-text { z-index: 1; }
  .hero-eyebrow {
    font-size: 0.7rem; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 1.5rem;
    display: flex; align-items: center; gap: 1rem;
  }
  .hero-eyebrow::before {
    content: ''; display: inline-block;
    width: 40px; height: 1px; background: var(--gold);
  }
  .hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.5rem, 6vw, 5.5rem);
    font-weight: 300; line-height: 1.05;
    margin-bottom: 1.5rem;
  }
  .hero h1 em { font-style: italic; color: var(--gold); }
  .hero-desc {
    font-size: 0.95rem; line-height: 1.8; color: var(--muted);
    max-width: 420px; margin-bottom: 3rem;
  }
  .hero-actions { display: flex; gap: 1rem; align-items: center; }
  .btn-primary {
    background: var(--gold); color: var(--dark);
    padding: 1rem 2.5rem; border: none; cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase;
    transition: all 0.3s; display: inline-block; text-decoration: none;
  }
  .btn-primary:hover { background: var(--gold-light); transform: translateY(-1px); }
  .btn-ghost {
    color: var(--cream); border: 1px solid var(--border);
    padding: 1rem 2.5rem; cursor: pointer; background: transparent;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase;
    transition: all 0.3s; text-decoration: none; display: inline-block;
  }
  .btn-ghost:hover { border-color: var(--gold); color: var(--gold); }

  .hero-visual {
    position: relative; display: flex; justify-content: center; align-items: center;
    height: 600px;
  }
  .hero-img-wrap {
    width: 420px; height: 520px; position: relative;
  }
  .hero-img-bg {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, #1a1916 0%, #2a2824 50%, #1a1916 100%);
    overflow: hidden;
  }
  .hero-img-bg::after {
    content: '';
    position: absolute; inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23b89c6e' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }
  .hero-building {
    position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
    width: 280px;
  }
  .hero-stats-float {
    position: absolute; left: -60px; bottom: 80px;
    background: var(--dark-mid); border: 1px solid var(--border);
    padding: 1.2rem 1.5rem;
  }
  .hero-stats-float .num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.2rem; color: var(--gold); font-weight: 300;
  }
  .hero-stats-float .label {
    font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--muted); margin-top: 0.2rem;
  }
  .hero-badge {
    position: absolute; right: -40px; top: 80px;
    background: var(--gold); color: var(--dark);
    padding: 1rem; width: 90px; height: 90px;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center; text-align: center;
  }
  .hero-badge .yr {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem; font-weight: 300; line-height: 1;
  }
  .hero-badge .yr-label {
    font-size: 0.55rem; letter-spacing: 0.15em; text-transform: uppercase; margin-top: 4px;
  }

  /* ─── STATS BAR ─── */
  .stats-bar {
    border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
    display: grid; grid-template-columns: repeat(4, 1fr);
    background: var(--dark-mid);
  }
  .stat-item {
    padding: 2.5rem; text-align: center;
    border-right: 1px solid var(--border);
  }
  .stat-item:last-child { border-right: none; }
  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3rem; font-weight: 300; color: var(--gold);
    line-height: 1;
  }
  .stat-label {
    font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--muted); margin-top: 0.5rem;
  }

  /* ─── SECTION COMMON ─── */
  section { padding: 6rem 4rem; }
  .section-tag {
    font-size: 0.65rem; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 1rem;
    display: flex; align-items: center; gap: 0.8rem;
  }
  .section-tag::after { content: ''; flex: 0 0 30px; height: 1px; background: var(--gold); }
  .section-h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 300; line-height: 1.1;
  }
  .section-h2 em { font-style: italic; color: var(--gold); }

  /* ─── PROJECTS ─── */
  .projects-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 4rem;
  }
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 1.5px;
    background: var(--border);
  }
  .project-card {
    background: var(--dark-mid);
    position: relative; overflow: hidden;
    cursor: pointer; transition: all 0.4s;
  }
  .project-card:first-child { grid-row: span 2; }
  .project-visual {
    width: 100%; overflow: hidden;
    position: relative;
  }
  .project-card:first-child .project-visual { height: 560px; }
  .project-card:not(:first-child) .project-visual { height: 260px; }
  .project-illustration {
    width: 100%; height: 100%;
    transition: transform 0.5s ease;
  }
  .project-card:hover .project-illustration { transform: scale(1.03); }
  .project-tag-type {
    position: absolute; top: 1.5rem; left: 1.5rem;
    background: var(--gold); color: var(--dark);
    font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase;
    padding: 0.3rem 0.8rem;
  }
  .project-info { padding: 1.5rem; }
  .project-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem; font-weight: 300; margin-bottom: 0.4rem;
  }
  .project-card:first-child .project-name { font-size: 2rem; }
  .project-loc {
    font-size: 0.7rem; letter-spacing: 0.1em; color: var(--muted);
    margin-bottom: 1rem;
  }
  .project-meta {
    display: flex; gap: 2rem;
  }
  .pm-item label {
    font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--muted); display: block; margin-bottom: 0.2rem;
  }
  .pm-item span {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem; color: var(--gold);
  }

  /* ─── SERVICES ─── */
  .services { background: var(--dark-mid); }
  .services-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1px; background: var(--border);
    margin-top: 4rem;
  }
  .service-card {
    background: var(--dark-mid); padding: 3rem 2.5rem;
    border-bottom: 3px solid transparent;
    transition: border-color 0.3s, background 0.3s;
    cursor: default;
  }
  .service-card:hover { border-color: var(--gold); background: var(--dark-soft); }
  .service-icon {
    width: 48px; height: 48px; margin-bottom: 2rem;
    color: var(--gold);
  }
  .service-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem; font-weight: 300; margin-bottom: 1rem;
  }
  .service-desc {
    font-size: 0.85rem; line-height: 1.8; color: var(--muted);
  }

  /* ─── AGENTS ─── */
  .agents-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 2rem; margin-top: 4rem;
  }
  .agent-card {
    position: relative; overflow: hidden;
    border: 1px solid var(--border);
    transition: border-color 0.3s;
  }
  .agent-card:hover { border-color: var(--gold); }
  .agent-visual { height: 320px; position: relative; overflow: hidden; }
  .agent-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(15,14,12,0.9) 0%, transparent 50%);
  }
  .agent-info { padding: 1.5rem; }
  .agent-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem; font-weight: 300; margin-bottom: 0.2rem;
  }
  .agent-role {
    font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 1rem;
  }
  .agent-contact {
    font-size: 0.8rem; color: var(--muted);
  }

  /* ─── TESTIMONIAL ─── */
  .testimonial-section {
    background: var(--cream);
    padding: 7rem 4rem;
    position: relative; overflow: hidden;
  }
  .testimonial-section::before {
    content: '\201C';
    position: absolute; top: -2rem; left: 3rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 20rem; color: rgba(184,156,110,0.08);
    line-height: 1; pointer-events: none;
  }
  .testimonial-section .section-tag { color: var(--gold-dark); }
  .testimonial-section .section-tag::after { background: var(--gold-dark); }
  .testimonial-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-style: italic; font-weight: 300;
    line-height: 1.4; color: var(--dark); max-width: 800px;
    margin: 2rem 0 3rem;
  }
  .testimonial-author { display: flex; align-items: center; gap: 1.5rem; }
  .author-avatar {
    width: 56px; height: 56px; border-radius: 50%;
    background: var(--gold-dark); display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem; color: var(--cream);
  }
  .author-name {
    font-size: 0.9rem; font-weight: 500; color: var(--dark); margin-bottom: 0.2rem;
  }
  .author-role { font-size: 0.75rem; color: var(--muted); }

  /* ─── CONTACT ─── */
  .contact-section {
    display: grid; grid-template-columns: 1fr 1fr;
    padding: 0; min-height: 600px;
  }
  .contact-left {
    background: var(--gold);
    padding: 6rem 4rem;
    display: flex; flex-direction: column; justify-content: center;
  }
  .contact-left .section-tag { color: var(--dark); }
  .contact-left .section-tag::after { background: var(--dark); }
  .contact-left .section-h2 { color: var(--dark); }
  .contact-left .section-h2 em { color: var(--dark-soft); }
  .contact-details { margin-top: 3rem; display: flex; flex-direction: column; gap: 1.5rem; }
  .contact-item label {
    font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(15,14,12,0.6); display: block; margin-bottom: 0.3rem;
  }
  .contact-item p {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem; color: var(--dark); font-weight: 300;
  }
  .contact-right {
    background: var(--dark-mid); padding: 6rem 4rem;
    display: flex; flex-direction: column; justify-content: center;
  }
  .form-group { margin-bottom: 1.5rem; }
  .form-group label {
    font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--muted); display: block; margin-bottom: 0.6rem;
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%; background: transparent;
    border: none; border-bottom: 1px solid var(--border);
    color: var(--cream); font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem; padding: 0.8rem 0;
    outline: none; transition: border-color 0.3s;
    appearance: none;
  }
  .form-group select option { background: var(--dark-mid); }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus { border-color: var(--gold); }
  .form-group textarea { resize: vertical; min-height: 80px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }

  /* ─── FOOTER ─── */
  footer {
    background: var(--dark); border-top: 1px solid var(--border);
    padding: 3rem 4rem;
    display: flex; align-items: center; justify-content: space-between;
  }
  .footer-copy {
    font-size: 0.75rem; color: var(--muted); letter-spacing: 0.05em;
  }
  .footer-links { display: flex; gap: 2rem; }
  .footer-links a {
    font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--muted); text-decoration: none; transition: color 0.3s;
  }
  .footer-links a:hover { color: var(--gold); }

  /* ─── SCROLL ANIMATIONS ─── */
  .fade-in {
    opacity: 0; transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .fade-in.visible { opacity: 1; transform: none; }

  @keyframes floatBadge {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  .hero-badge { animation: floatBadge 4s ease-in-out infinite; }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="logo">Meridian <span>Estate</span></div>
  <ul>
    <li><a href="#projekty">Projekty</a></li>
    <li><a href="#uslugi">Usługi</a></li>
    <li><a href="#zespol">Zespół</a></li>
    <li><a href="#kontakt">Kontakt</a></li>
  </ul>
  <button class="nav-cta">Umów konsultację</button>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-text fade-in">
    <div class="hero-eyebrow">Prestiżowa Agencja Nieruchomości</div>
    <h1>Twoja wymarzona<br><em>nieruchomość</em><br>czeka na Ciebie</h1>
    <p class="hero-desc">Oferujemy dostęp do wyjątkowych nieruchomości premium w najlepszych lokalizacjach. Profesjonalne doradztwo, transparentny proces, bezprecedensowa obsługa.</p>
    <div class="hero-actions">
      <a href="#projekty" class="btn-primary">Przeglądaj oferty</a>
      <a href="#kontakt" class="btn-ghost">Skontaktuj się</a>
    </div>
  </div>
  <div class="hero-visual">
    <!-- Building illustration -->
    <div class="hero-img-wrap">
      <div class="hero-img-bg">
        <svg class="hero-building" viewBox="0 0 280 400" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Sky gradient -->
          <defs>
            <linearGradient id="skyGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#0F0E0C"/>
              <stop offset="100%" stop-color="#1A1916"/>
            </linearGradient>
          </defs>
          <!-- Main tower -->
          <rect x="60" y="60" width="160" height="340" fill="#1a1916"/>
          <!-- Tower accent lines -->
          <rect x="60" y="60" width="160" height="4" fill="#B89C6E" opacity="0.6"/>
          <!-- Windows grid -->
          <g fill="#B89C6E" opacity="0.35">
            <rect x="80" y="90" width="20" height="28"/><rect x="116" y="90" width="20" height="28"/><rect x="152" y="90" width="20" height="28"/>
            <rect x="80" y="134" width="20" height="28"/><rect x="116" y="134" width="20" height="28"/><rect x="152" y="134" width="20" height="28"/>
            <rect x="80" y="178" width="20" height="28"/><rect x="116" y="178" width="20" height="28"/><rect x="152" y="178" width="20" height="28"/>
            <rect x="80" y="222" width="20" height="28"/><rect x="116" y="222" width="20" height="28"/><rect x="152" y="222" width="20" height="28"/>
            <rect x="80" y="266" width="20" height="28"/><rect x="116" y="266" width="20" height="28"/><rect x="152" y="266" width="20" height="28"/>
            <rect x="80" y="310" width="20" height="28"/><rect x="116" y="310" width="20" height="28"/><rect x="152" y="310" width="20" height="28"/>
          </g>
          <!-- Lit windows -->
          <g fill="#D4B88A" opacity="0.8">
            <rect x="116" y="90" width="20" height="28"/>
            <rect x="80" y="178" width="20" height="28"/>
            <rect x="152" y="222" width="20" height="28"/>
            <rect x="116" y="310" width="20" height="28"/>
            <rect x="80" y="266" width="20" height="28"/>
          </g>
          <!-- Entrance -->
          <rect x="110" y="340" width="60" height="60" fill="#2a2824"/>
          <rect x="120" y="350" width="40" height="50" fill="#B89C6E" opacity="0.15"/>
          <!-- Steps -->
          <rect x="90" y="395" width="100" height="5" fill="#2a2824"/>
          <!-- Side buildings -->
          <rect x="0" y="200" width="55" height="200" fill="#141412"/>
          <rect x="225" y="180" width="55" height="220" fill="#141412"/>
          <!-- Side windows -->
          <g fill="#B89C6E" opacity="0.2">
            <rect x="12" y="215" width="14" height="20"/><rect x="34" y="215" width="14" height="20"/>
            <rect x="12" y="248" width="14" height="20"/><rect x="34" y="248" width="14" height="20"/>
            <rect x="12" y="281" width="14" height="20"/><rect x="34" y="281" width="14" height="20"/>
            <rect x="237" y="195" width="14" height="20"/><rect x="259" y="195" width="14" height="20"/>
            <rect x="237" y="228" width="14" height="20"/><rect x="259" y="228" width="14" height="20"/>
            <rect x="237" y="261" width="14" height="20"/><rect x="259" y="261" width="14" height="20"/>
          </g>
          <!-- Decorative top spire -->
          <rect x="132" y="30" width="16" height="32" fill="#B89C6E" opacity="0.7"/>
          <polygon points="140,10 128,32 152,32" fill="#B89C6E" opacity="0.9"/>
          <!-- Ground line with glow -->
          <line x1="0" y1="400" x2="280" y2="400" stroke="#B89C6E" stroke-width="1" opacity="0.3"/>
        </svg>
      </div>
    </div>
    <div class="hero-stats-float">
      <div class="num">850+</div>
      <div class="label">Sprzedanych nieruchomości</div>
    </div>
    <div class="hero-badge">
      <div class="yr">15</div>
      <div class="yr-label">lat doświadczenia</div>
    </div>
  </div>
</section>

<!-- STATS BAR -->
<div class="stats-bar fade-in">
  <div class="stat-item">
    <div class="stat-num">850+</div>
    <div class="stat-label">Transakcji rocznie</div>
  </div>
  <div class="stat-item">
    <div class="stat-num">98%</div>
    <div class="stat-label">Zadowolonych klientów</div>
  </div>
  <div class="stat-item">
    <div class="stat-num">12</div>
    <div class="stat-label">Miast w Polsce</div>
  </div>
  <div class="stat-item">
    <div class="stat-num">2,1 mld</div>
    <div class="stat-label">Wartość portfela zł</div>
  </div>
</div>

<!-- PROJECTS -->
